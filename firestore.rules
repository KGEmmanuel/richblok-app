rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isPro() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data.subscription_tier in ['pro', 'team'];
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Users (utilisateurs collection — French naming kept for backward compat)
    match /utilisateurs/{userId} {
      // Anyone can read public profile fields, but only owner can read full doc
      allow read: if true;
      // Only owner can create/update their own profile, NEVER subscription_* fields client-side
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    && !('subscription_tier' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('subscription_status' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('stripe_customer_id' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('stripe_subscription_id' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if false; // Users cannot self-delete; require admin/Cloud Function

      // Subcollections
      match /formations/{formationId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /experiences/{expId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /competences/{compId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /arch_formations/{id} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /arch_competences/{id} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /arch_experience/{id} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Posts (feed)
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.owner == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.owner == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.owner == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && resource.data.owner == request.auth.uid;
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
                  (resource.data.recipient == request.auth.uid ||
                   request.auth.uid in resource.data.abonnees);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipient == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipient == request.auth.uid;
    }

    // Challenges
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.creatorRef == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.creatorRef == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.creatorRef == request.auth.uid;
    }

    // Challenge submissions (rate-limited for free users)
    match /challenge_submissions/{subId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if false; // Only via Cloud Function
      allow update, delete: if false;
    }

    // Job offers
    match /offresEmploi/{jobId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Job applications
    match /jobApplications/{appId} {
      allow read: if isAuthenticated() &&
                  (resource.data.applicantUid == request.auth.uid ||
                   resource.data.recruiterUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.applicantUid == request.auth.uid;
      allow update: if isAuthenticated() &&
                    (resource.data.applicantUid == request.auth.uid ||
                     resource.data.recruiterUid == request.auth.uid);
      allow delete: if false;
    }

    // Organisations
    match /organisations/{orgId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.admins;
    }

    // Chat rooms & messages
    match /chatRooms/{roomId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthenticated() &&
                    request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        allow create: if isAuthenticated() &&
                      request.resource.data.sender == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Stripe checkout sessions (write-only by client; Cloud Function reads)
    match /stripe_checkout_sessions/{sessionId} {
      allow read: if false;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Reference data (read-only for all)
    match /pays/{paysId} {
      allow read: if true;
      allow write: if false;
    }
    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
